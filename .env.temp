# Resume Parser Environment Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider Configuration
# (Bedrock only)

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=PUT_YOUR_KEY_HERE
AWS_SECRET_ACCESS_KEY=AoiCuHV3x+PUT_YOUR_KEY_HERE
BEDROCK_MODEL=meta.llama3-8b-instruct-v1:0


# FastAPI Backend Configuration
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# Streamlit Frontend Configuration
STREAMLIT_PORT=8501

# AWS/DynamoDB Configuration (Optional)
USE_DYNAMODB=false
AWS_REGION=us-east-1
DYNAMODB_TABLE=resume_results

# File Upload Configuration
MAX_FILE_SIZE_MB=10
